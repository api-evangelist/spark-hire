          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"interview_uuid\": \"\",\n  \"password_protected\": false,\n  \"allow_ratings\": true\n}" },
            "url": { "raw": "{{baseUrl}}/share_links", "host": ["{{baseUrl}}"], "path": ["share_links"] }
          }
