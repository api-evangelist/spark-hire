          }
        },
        {
          "name": "Update advanced share link",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"allow_ratings\": false\n}" },
            "url": { "raw": "{{baseUrl}}/share_links/:uuid", "host": ["{{baseUrl}}"], "path": ["share_links", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] }
          }
        },
        {
          "name": "Delete advanced share link",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/share_links/:uuid", "host": ["{{baseUrl}}"], "path": ["share_links", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "List webhooks",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/webhooks", "host": ["{{baseUrl}}"], "path": ["webhooks"] }
          }
        },
        {
          "name": "Create a webhook",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"url\": \"https://example.com/hooks/spark-hire\",\n  \"event\": \"InterviewCompleted\"\n}" },
            "url": { "raw": "{{baseUrl}}/webhooks", "host": ["{{baseUrl}}"], "path": ["webhooks"] }
          }
        },
        {
          "name": "Delete a webhook",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/webhooks/:uuid", "host": ["{{baseUrl}}"], "path": ["webhooks", ":uuid"], "variable": [{ "key": "uuid", "value": "" }] }
          }
        },
        {
          "name": "Replay a webhook event",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/webhooks/replay/:event", "host": ["{{baseUrl}}"], "path": ["webhooks", "replay", ":event"], "variable": [{ "key": "event", "value": "InterviewCompleted" }] }
          }
        }
      ]
    }
  ]
}
